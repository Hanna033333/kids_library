# 책자리 백엔드 환경변수 설정 가이드
# 이 파일을 복사하여 .env 파일을 생성하세요: cp .env.example .env

# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase 프로젝트 URL (Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 서비스 롤 키 (Settings > API > service_role) - 서버사이드 전용, 절대 프론트엔드 노출 금지
SUPABASE_KEY=your-service-role-key

# ─── Threads API ──────────────────────────────────────────────────────────────
# Meta Threads 앱 액세스 토큰
THREADS_ACCESS_TOKEN=your-threads-access-token

# Threads 사용자 ID
THREADS_USER_ID=your-threads-user-id

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# 텔레그램 관리자 채팅 ID
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Google Gemini API 키 (AI studio에서 발급)
GEMINI_API_KEY=your-gemini-api-key

# ─── 배포 설정 ────────────────────────────────────────────────────────────────
# 백엔드 서버 공개 URL (Render 배포 시: https://your-app.onrender.com)
# 로컬 테스트 시: http://lvh.me:8000 (localhost 대신 사용해야 텔레그램 인라인 버튼 URL이 허용됨)
BACKEND_URL=https://your-backend.onrender.com

# 환경 구분 (production 설정 시 일부 sync API가 비활성화됨)
ENV=production

# ─── 관리자 토큰 ──────────────────────────────────────────────────────────────
# Threads 관리자 API 인증 토큰 (임의의 안전한 문자열로 변경 권장)
THREADS_ADMIN_TOKEN=your-secure-admin-token-here
